# Sentinel — 环境变量模板
#
# 复制本文件为 .env 并填入真实值：
#   cp deploy/.env.example deploy/.env
#
# 重要：.env 已在 .gitignore 中，永远不要提交真实密钥到 git！

# ============================================================
# freqtrade Telegram 接入（明天起床后填）
# ============================================================
# 在 Telegram 与 @BotFather 对话创建机器人，获取 token
# Telegram user_id 可向 @userinfobot 发送任意消息获取
# 注意：user_id 是数字，不是 username
FREQTELEGRAM__TELEGRAM_TOKEN=
FREQTELEGRAM__CHAT_ID=
FREQTELEGRAM__ALLOWED_CHAT_IDS=

# ============================================================
# Webhook（AI 服务用，Phase 2 才需要）
# ============================================================
WEBHOOK_URL=
WEBHOOK_PORT=

# ============================================================
# AI service webhook (P2.5)
# freqtrade 在平仓时向这里 POST /trade-close 触发自动 reflection
# docker-compose 用 host 网络模式，ai-service 同 host 时直接 127.0.0.1:8000
# 默认值与 deploy/.env 保持一致
# ============================================================
AI_SERVICE_WEBHOOK_URL=http://127.0.0.1:8000/trade-close

# ============================================================
# Telegram inbound webhook 源校验 (RS.1)
# 注册 webhook 时通过 Telegram 的 setWebhook secret_token 设置同一值：
#   curl -F "url=https://<host>/telegram/webhook" \
#        -F "secret_token=<此处的值>" \
#        https://api.telegram.org/bot<BOT_TOKEN>/setWebhook
# Telegram 会在每次回调时带上 header:
#   X-Telegram-Bot-Api-Secret-Token: <此处的值>
# ai-service 校验该 header，不匹配则静默丢弃（返回 200，不处理、不回复）。
# 留空 = 开发模式（不校验来源，仅记录一次警告）。生产必须设置。
# ============================================================
TELEGRAM_WEBHOOK_SECRET=

# ============================================================
# 运行环境 (RS.2)
# dev  = 本地开发：无 LLM key 时回退 sk-fake-for-dev，服务照常启动
# prod = 生产/VPS：未设置 AGNES_API_KEY / OPENAI_API_KEY 时拒绝启动，
#        避免用假 key 静默 401、/healthz 却显示健康的隐形故障。
# 留空 = dev。
# ============================================================
SENTINEL_ENV=dev

# ============================================================
# AI service OPS 端点共享令牌 (RS.3)
# 保护「人/仪表盘」调用的写端点：
#   POST /strategy/register, POST /strategy/check,
#   POST /research/note,      POST /reflection
# 设置后这些端点要求请求头 X-Sentinel-Token: <此处的值>，不匹配则 401。
# 留空 = 不校验（开发/测试照常工作）。生产/VPS 建议设一个随机长串：
#   openssl rand -hex 32
# 注意：/veto 和 /trade-close 故意不加令牌（由本机 freqtrade 调用，
#       无法发自定义头），改由 loopback 绑定 + 防火墙做网络隔离保护。
# ============================================================
SENTINEL_API_TOKEN=

# ============================================================
# LLM API（Phase 2 才需要，留空即可）
# ============================================================
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
LLM_QUICK_MODEL=gpt-4o-mini
LLM_DEEP_MODEL=gpt-4o

# ============================================================
# 异步 LLM 否决预计算 (ADR-002, docs §2.2)
# GET /veto 保持快速（请求内不调用 LLM）：后台任务按 cron 对「策略最近
# 查询过的 (strategy, pair)」批量跑 LLM 魔鬼代言人否决，结果写入
# veto_records(source="llm")。GET /veto 命中新鲜的预计算否决即可拦单，
# 无需在请求内等待 LLM。
#
# SCHEDULER_VETO_CRON — 预计算任务的 cron（默认每 15 分钟一次，控制 LLM 成本）。
#   留空 = 默认 "*/15 * * * *"。
# VETO_LLM_TTL_MIN    — GET /veto 认可预计算否决的新鲜度窗口（分钟，默认 15）。
#   超过该窗口的 llm 否决记录视为过期，不再拦单（fail-open 放行）。
# ============================================================
SCHEDULER_VETO_CRON=*/15 * * * *
VETO_LLM_TTL_MIN=15