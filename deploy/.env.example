# Sentinel — 环境变量模板
#
# 复制本文件为 .env 并填入真实值：
#   cp deploy/.env.example deploy/.env
#
# 重要：.env 已在 .gitignore 中，永远不要提交真实密钥到 git！

# ============================================================
# freqtrade Telegram 接入（明天起床后填）
# ============================================================
# 在 Telegram 与 @BotFather 对话创建机器人，获取 token
# Telegram user_id 可向 @userinfobot 发送任意消息获取
# 注意：user_id 是数字，不是 username
FREQTELEGRAM__TELEGRAM_TOKEN=
FREQTELEGRAM__CHAT_ID=
FREQTELEGRAM__ALLOWED_CHAT_IDS=

# ============================================================
# Webhook（AI 服务用，Phase 2 才需要）
# ============================================================
WEBHOOK_URL=
WEBHOOK_PORT=

# ============================================================
# LLM API（Phase 2 才需要，留空即可）
# ============================================================
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
LLM_QUICK_MODEL=gpt-4o-mini
LLM_DEEP_MODEL=gpt-4o